{
	"hosting": {
		"public": "dist",
		"ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
		"rewrites": [
			{
				"source": "/privacy-policy",
				"destination": "/privacy-policy.html"
			},
			{
				"source": "/terms-conditions",
				"destination": "/terms-and-conditions.html"
			},
			{
				"source": "**",
				"destination": "/index.html"
			}
		]
	}
}
